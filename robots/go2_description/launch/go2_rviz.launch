<?xml version="1.0" encoding="UTF-8"?>
<launch>

    <arg name="user_debug" default="false"/>
    
    <!-- send fake joint values -->
    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" name="joint_state_publisher_gui">
        <param name="use_gui" value="true"/>
    </node>

    <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
        <param name="publish_frequency" value="100.0"/>
        <!--<param name="robot_description"  type="str" value="$(command 'xacro $(find-pkg-share go2_description)/urdf/go2_description.urdf')" />-->
        <param name="robot_description"  type="str" value="$(command 'xacro $(find-pkg-share go2_description)/xacro/robot.xacro')" />        
    </node>

    <node pkg="rviz2" exec="rviz2" name="rviz" respawn="false" output="screen"
        args="-d $(find-pkg-share go2_description)/launch/check_joint.rviz"/>

</launch>
