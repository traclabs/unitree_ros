<?xml version="1.0" encoding="UTF-8"?>
<launch>
  
  <arg name="x" default="0.0"/>
  <arg name="y" default="0.2"/>
  <arg name="z" default="0.5"/>    
  <arg name="yaw" default="0.4"/>
  <arg name="world" default="ionic_reduced"/> <!-- ionic_reduced living_room ground_plane-->  
  <arg name="robot_up" default="10.0"/>

  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="$(find-pkg-share go2_description)/worlds/$(var world).sdf -r -v 4"/>
  </include>
    
  <node
    name="tf_footprint_base"
    pkg="tf2_ros"
    exec="static_transform_publisher"
    args="--x 0 --y 0 --z 0 --roll 0 --pitch 0 --yaw 0 --frame-id base_link --child-frame-id base_footprint" />

  <!-- $(find-pkg-share go2_description)/urdf/go2_description.urdf"-->  
  <!-- $(find-pkg-share go2_description)/xacro/robot.urdf.xacro" -->  
  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
    <param name="publish_frequency" value="100.0"/>
    <param name="robot_description"  type="str" value="$(command 'xacro $(find-pkg-share go2_description)/xacro/robot.urdf.xacro')" />
    <param name="use_sim_time" value="true"/>            
  </node>  

  <include file="$(find-pkg-share go2_description)/launch/spawn_go2.launch.py">
    <arg name="x" value="$(var x)"/>
    <arg name="y" value="$(var y)"/>
    <arg name="z" value="$(var z)"/>
    <arg name="yaw" value="$(var yaw)"/>
    <arg name="robot_up" value="$(var robot_up)"/>        
  </include>  

<!--  <node
    name="fake_joint_calibration"
    pkg="rostopic"
    exec="rostopic"
    args="pub /calibrated std_msgs/Bool true" />-->


</launch>
